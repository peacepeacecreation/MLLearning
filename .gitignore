# ─── Secrets — API keys, tokens, credentials ────────────────────────
# Патерни без leading `/` — ловлять на будь-якій глибині.
# Якщо будь-де в дереві зʼявиться .env з реальними ключами, git його не побачить.
.env
.env.local
.env.production
.env.development
*.key
*.pem
secrets.json
credentials.json

# ─── Private mentor prep ────────────────────────────────────────────
# Cheat-sheets, research notes — для мене (ментора), не для читача
lessons/

# ─── Personal knowledge profile ─────────────────────────────────────
# Живий профіль знань + сесійні нотатки — приватне
memories/

# ─── Local tooling settings ─────────────────────────────────────────
# Ігноруємо все в .claude/ окрім /commands/ — команди частина проєкту,
# налаштування локальні.
.claude/*
!.claude/commands/

# ─── Voice-agent runtime data ───────────────────────────────────────
# Транскрипти голосових сесій можуть містити особисту інформацію
transcripts/
tmp/

# Symlink voice/transcripts → ../memories/transcripts (локальне рішення,
# не commit-имо ні сам симлінк, ні його ціль — memories/ уже ігнорується)
voice/transcripts

# ─── Python ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/
venv/
.venv/
env/

# ─── Jupyter ────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Node ───────────────────────────────────────────────────────────
node_modules/

# ─── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp


# --- ML data --------------------------------------------------------
# Dataset - велике, комітити через LFS або DVC якщо потрібно
data/raw/
data/processed/
data/interim/
*.parquet
*.feather
*.h5
*.hdf5

# --- ML models & checkpoints ----------------------------------------
# Треновані моделі - бінарники
models/
checkpoints/
*.pkl
*.joblib
*.pt
*.pth
*.onnx
*.tflite
*.safetensors

# --- Experiment tracking --------------------------------------------
mlruns/
wandb/
lightning_logs/
